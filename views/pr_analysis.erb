<h1>PR #<%= @pr_number %>: <%= @pr_title %></h1>
<p>
  Author: <%= @pr_author %> |
  CI Status: <span class="ci-status ci-<%= @ci_status %>"><%= {green: "Green", pending_clean: "Pending", pending_failing: "Pending (failing)", failed: "Failed", unknown: "Unknown"}[@ci_status] %></span>
</p>
<p><a href="/">Home</a> | <a href="https://github.com/DataDog/dd-trace-rb/pull/<%= @pr_number %>">View on GitHub</a></p>

<% if @use_streaming %>
<!-- Streaming mode - progressive rendering -->

<!-- Auto-restart notice (populated by SSE) -->
<div id="auto-restart-notice" style="display: none;" class="card"></div>

<!-- Download errors notice (populated by SSE) -->
<div id="download-errors-notice" style="display: none;" class="card"></div>

<!-- Job Summary -->
<div id="job-summary-section">
  <p id="job-summary-loading" style="color: #999;">
    <strong>&mdash;</strong> passed,
    <strong>&mdash;</strong> failed
  </p>
  <div id="job-summary-content"></div>
</div>

<!-- Categorized Failures -->
<div id="categorized-failures-section">
  <div id="categorized-loading" class="card" style="color: #999;">
    <p>Loading failures...</p>
  </div>
  <div id="categorized-content"></div>
</div>

<!-- Test Details -->
<div id="test-details-section">
  <div id="test-details-loading" class="card" style="color: #999;">
    <h2>Test Failure Details</h2>
    <p>Loading test results...</p>
  </div>
  <div id="test-details-content"></div>
</div>

<!-- Meta Failures (populated by SSE if present) -->
<div id="meta-failures-section" style="display: none;"></div>

<noscript>
  <meta http-equiv="refresh" content="10">
  <p>⏳ Analyzing PR #<%= @pr_number %>... (page will refresh automatically)</p>
</noscript>

<style>
.badge-flaky {
  background: #ffc107;
  color: #000;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 0.85em;
  font-weight: bold;
}
</style>

<script>
(function() {
  const prNumber = <%= @pr_number %>;
  const ciStatus = '<%= @ci_status %>';
  const eventSource = new EventSource('/pr/' + prNumber + '/stream?ci_status=' + ciStatus);

  eventSource.addEventListener('job_list', function(e) {
    document.getElementById('job-summary-loading').style.display = 'none';
    const data = JSON.parse(e.data);

    const html = '<p><strong>' + data.passed_jobs + '</strong> passed, ' +
                 '<strong>' + data.failed_jobs + '</strong> failed' +
                 (data.in_progress > 0 ? ', <strong>' + data.in_progress + '</strong> in progress' : '') +
                 '</p>';

    document.getElementById('job-summary-content').innerHTML = html;
  });

  eventSource.addEventListener('categorized_failures_initial', function(e) {
    document.getElementById('categorized-loading').style.display = 'none';
    const data = JSON.parse(e.data);

    let html = '';

    if (data.categorized && Object.keys(data.categorized).length > 0) {
      for (const [category, failures] of Object.entries(data.categorized)) {
        html += renderCategoryCard(category, failures);
      }
    } else {
      html = '<div class="card"><p>No CI failures found for this PR.</p></div>';
    }

    document.getElementById('categorized-content').innerHTML = html;
  });

  eventSource.addEventListener('categorized_failures_final', function(e) {
    const data = JSON.parse(e.data);

    // Show auto-restart notice if applicable
    if (data.auto_restarted) {
      const notice = document.getElementById('auto-restart-notice');
      notice.style.display = 'block';
      notice.style.background = '#fff3cd';
      notice.style.borderLeft = '4px solid #ffc107';
      notice.innerHTML = '<p style="margin: 0;">ℹ️ Automatically restarted the "all-jobs-are-green" job. Refresh the page in a moment to see updated status.</p>';
    }

    let html = '';

    if (data.categorized && Object.keys(data.categorized).length > 0) {
      for (const [category, failures] of Object.entries(data.categorized)) {
        html += renderCategoryCard(category, failures);
      }
    } else {
      html = '<div class="card"><p>No CI failures found for this PR.</p></div>';
    }

    document.getElementById('categorized-content').innerHTML = html;

    // Render meta failures if present
    if (data.meta_failures && data.meta_failures.length > 0) {
      const metaSection = document.getElementById('meta-failures-section');
      metaSection.style.display = 'block';
      metaSection.innerHTML = renderMetaFailures(data.meta_failures);
    }
  });

  eventSource.addEventListener('test_details', function(e) {
    document.getElementById('test-details-loading').style.display = 'none';
    const data = JSON.parse(e.data);

    if (data.aggregated && data.aggregated.length > 0) {
      document.getElementById('test-details-content').innerHTML = renderTestDetails(data);
    }
  });

  eventSource.addEventListener('complete', function(e) {
    console.log('Analysis complete');
    eventSource.close();
  });

  eventSource.addEventListener('error', function(e) {
    console.error('SSE error:', e);

    // Show error message
    document.getElementById('job-summary-content').innerHTML =
      '<p>❌ Connection lost. <a href="javascript:location.reload()">Refresh page</a></p>';

    // Auto-refresh after 5 seconds
    setTimeout(function() { window.location.reload(); }, 5000);
  });

  function renderCategoryCard(category, failures) {
    const categoryLabels = {
      meta: "Meta",
      infrastructure: "Infrastructure",
      type_check: "Type Check",
      lint: "Lint",
      security: "Security",
      tests: "Tests",
      build: "Build",
      uncategorized: "Uncategorized"
    };

    let html = '<div class="card">';
    html += '<h2>' + (categoryLabels[category] || category) + ' (' + failures.length + ')</h2>';
    html += '<table><thead><tr><th>Job</th><th></th></tr></thead><tbody>';

    failures.forEach(function(failure) {
      html += '<tr><td>';
      html += escapeHtml(failure.job_name);

      if (failure.details) {
        html += '<details style="margin-top: 8px;">';
        html += '<summary style="cursor: pointer; color: #333; font-size: 0.9em;">Show error details</summary>';
        html += '<pre style="margin-top: 8px; padding: 8px; background: #f5f5f5; border-radius: 4px; overflow-x: auto; font-size: 0.85em; color: #000;">';
        html += escapeHtml(failure.details);
        html += '</pre></details>';
      }

      html += '</td><td><a href="' + escapeHtml(failure.url) + '" target="_blank">View Logs</a></td></tr>';
    });

    html += '</tbody></table></div>';
    return html;
  }

  function renderMetaFailures(failures) {
    let html = '<div class="card" style="opacity: 0.7;">';
    html += '<h2>Also Failed</h2>';
    const jobWord = failures.length === 1 ? 'job' : 'jobs';
    html += '<p style="margin-bottom: 10px;"><small>These meta-check ' + jobWord + ' also failed, but this is expected when other jobs fail:</small></p>';
    html += '<table><thead><tr><th>Job</th><th></th></tr></thead><tbody>';

    failures.forEach(function(failure) {
      html += '<tr><td>' + escapeHtml(failure.job_name) + '</td>';
      html += '<td><a href="' + escapeHtml(failure.url) + '" target="_blank">View Logs</a></td></tr>';
    });

    html += '</tbody></table></div>';
    return html;
  }

  function renderTestDetails(data) {
    let html = '<div class="card">';
    html += '<h2>Test Failure Details</h2>';
    html += '<p><strong>' + data.unique_tests + '</strong> failed tests';
    if (data.flaky_tests > 0) {
      html += ' (<strong>' + data.flaky_tests + '</strong> flaky)';
    }
    html += '</p>';
    html += '<input type="text" class="search" placeholder="Filter tests...">';
    html += '<table><thead><tr><th>Test</th><th>Failures</th><th>Status</th></tr></thead><tbody>';

    data.aggregated.forEach(function(failure) {
      html += '<tr class="expandable">';
      html += '<td><strong>' + escapeHtml(failure.test_class) + '</strong><br>';
      html += '<code>' + escapeHtml(failure.test_name) + '</code></td>';
      html += '<td>' + failure.failure_count;
      if (failure.pass_count > 0) {
        html += ' / ' + failure.pass_count + ' passed';
      }
      html += '</td><td>';

      if (failure.pass_count > 0 && failure.failure_count > 0) {
        html += '<span class="badge-flaky">Flaky</span>';
      }

      html += '</td></tr>';

      // Expand details row
      html += '<tr class="details"><td colspan="3">';
      failure.instances.forEach(function(instance, i) {
        html += '<h4>Instance ' + (i + 1);
        if (instance.status === 'passed') {
          html += ' <span style="color: #28a745;">✓ PASSED</span>';
        } else {
          html += ' <span style="color: #dc3545;">✗ FAILED</span>';
        }
        html += '</h4>';

        if (instance.status === 'failed' || instance.status === ':failed') {
          if (instance.failure_message) {
            html += '<p><strong>Message:</strong> ' + escapeHtml(instance.failure_message) + '</p>';
          }
          if (instance.stack_trace && instance.stack_trace.length > 0) {
            html += '<pre>' + escapeHtml(instance.stack_trace) + '</pre>';
          }
        }

        if (instance.build_context) {
          html += '<p><small>Run: ' + instance.build_context.run_id;
          if (instance.build_context.job_name) {
            html += ' | Job: ' + escapeHtml(instance.build_context.job_name);
          }
          html += '</small></p>';
        }
      });
      html += '</td></tr>';
    });

    html += '</tbody></table></div>';
    return html;
  }

  function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }
})();
</script>

<% else %>
<!-- Non-streaming mode (fallback) -->
<% if @results[:auto_restarted] %>
<div class="card" style="background: #fff3cd; border-left: 4px solid #ffc107;">
  <p style="margin: 0;">ℹ️ Automatically restarted the "<%= Bells::META_CHECK_JOB_NAME %>" job. Refresh the page in a moment to see updated status.</p>
</div>
<% end %>

<% if @results[:download_errors]&.any? %>
<div class="card" style="background: #f8d7da; border-left: 4px solid #dc3545;">
  <h3 style="margin-top: 0; color: #721c24;">Artifact Download Errors</h3>
  <ul style="margin: 0;">
    <% @results[:download_errors].each do |error| %>
      <li><%= error %></li>
    <% end %>
  </ul>
</div>
<% end %>

<p>
  <strong><%= @results[:passed_jobs] %></strong> passed,
  <strong><%= @results[:total_failed_jobs] %></strong> failed<% if @results[:in_progress_jobs] > 0 %>, <strong><%= @results[:in_progress_jobs] %></strong> in progress<% end %> •
  <strong><%= @results[:test_details][:unique_tests] %></strong> failed tests<% if @results[:test_details][:flaky_tests] > 0 %> (<strong><%= @results[:test_details][:flaky_tests] %></strong> flaky)<% end %>
</p>

<% if @results[:categorized_failures].any? %>
  <% @results[:categorized_failures].each do |category, failures| %>
  <div class="card">
    <h2><%= Bells::FailureCategorizer.category_label(category) %> (<%= failures.size %>)</h2>
    <table>
      <thead>
        <tr>
          <th>Job</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% failures.each do |failure| %>
        <tr>
          <td>
            <%= failure.job_name %>
            <% if failure.details %>
              <details style="margin-top: 8px;">
                <summary style="cursor: pointer; color: #333; font-size: 0.9em;">Show error details</summary>
                <pre style="margin-top: 8px; padding: 8px; background: #f5f5f5; border-radius: 4px; overflow-x: auto; font-size: 0.85em; color: #000;"><%= failure.details %></pre>
              </details>
            <% end %>
          </td>
          <td><a href="<%= failure.url %>" target="_blank">View Logs</a></td>
        </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% end %>
<% else %>
<div class="card">
  <p>No CI failures found for this PR.</p>
</div>
<% end %>

<% if @results[:test_details][:aggregated].any? %>
<div class="card">
  <h2>Test Failure Details</h2>
  <input type="text" class="search" placeholder="Filter tests...">
  <table>
    <thead>
      <tr>
        <th>Test</th>
        <th>Failures</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @results[:test_details][:aggregated].each do |failure| %>
      <tr class="expandable">
        <td>
          <strong><%= failure.test_class %></strong><br>
          <code><%= failure.test_name %></code>
        </td>
        <td><%= failure.failure_count %><% if failure.pass_count > 0 %> / <%= failure.pass_count %> passed<% end %></td>
        <td>
          <% if failure.flaky? %>
            <span class="badge badge-flaky">Flaky</span>
          <% end %>
        </td>
      </tr>
      <tr class="details">
        <td colspan="3">
          <% failure.instances.each_with_index do |instance, i| %>
            <h4>Instance <%= i + 1 %> <% if instance.status == :passed %><span style="color: #28a745;">✓ PASSED</span><% else %><span style="color: #dc3545;">✗ FAILED</span><% end %></h4>
            <% if instance.status == :failed %>
              <% if instance.failure_message %>
                <p><strong>Message:</strong> <%= instance.failure_message %></p>
              <% end %>
              <% if instance.stack_trace && !instance.stack_trace.empty? %>
                <pre><%= instance.stack_trace %></pre>
              <% end %>
            <% end %>
            <% if instance.build_context %>
              <p><small>
                Run: <%= instance.build_context.run_id %>
                <% if instance.build_context.job_name %>
                  | Job: <%= instance.build_context.job_name %>
                <% end %>
              </small></p>
            <% end %>
          <% end %>
        </td>
      </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>

<% if @results[:meta_failures] %>
<div class="card" style="opacity: 0.7;">
  <h2>Also Failed</h2>
  <p style="margin-bottom: 10px;"><small>These meta-check <%= @results[:meta_failures].size == 1 ? 'job' : 'jobs' %> also failed, but this is expected when other jobs fail:</small></p>
  <table>
    <thead>
      <tr>
        <th>Job</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @results[:meta_failures].each do |failure| %>
      <tr>
        <td><%= failure.job_name %></td>
        <td><a href="<%= failure.url %>" target="_blank">View Logs</a></td>
      </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>

<% end %>
