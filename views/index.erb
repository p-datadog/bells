<h1>bells</h1>
<p>CI Failure Analysis for dd-trace-rb</p>

<div class="card">
  <h2>Analyze Pull Request</h2>
  <form action="/pr" method="get" onsubmit="window.location='/pr/'+this.pr.value; return false;">
    <input type="number" name="pr" placeholder="PR number" required>
    <button type="submit">Analyze</button>
  </form>
</div>

<div class="card">
  <h2>Open Pull Requests</h2>
  <div class="filters">
    <a href="/"<%= ' class="active"' unless @author_filter %>>All</a>
    <% @authors.each do |author| %>
      <a href="/?author=<%= author %>"<%= ' class="active"' if @author_filter == author %>><%= author %></a>
    <% end %>
  </div>
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Title</th>
        <th>Author</th>
        <th>CI</th>
        <th>Updated</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @pull_requests.each do |pr| %>
      <tr>
        <td><%= pr.number %></td>
        <td><a href="<%= pr.html_url %>"><%= pr.title %></a></td>
        <td><%= pr.user.login %></td>
        <td><span class="ci-status ci-<%= @ci_status[pr.number] %>"><%= {green: "Green", pending_clean: "Pending", pending_failing: "Pending (failing)", failed: "Failed", unknown: "Unknown"}[@ci_status[pr.number]] %></span></td>
        <td><%= pr.updated_at.strftime("%Y-%m-%d") %></td>
        <td><a href="/pr/<%= pr.number %>">Analyze</a></td>
      </tr>
      <% end %>
    </tbody>
  </table>
</div>
