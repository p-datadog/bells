#!/usr/bin/env ruby
# frozen_string_literal: true

require 'optparse'

options = {}
OptionParser.new do |opts|
  opts.banner = "Usage: bin/bells [options]"

  opts.on("-a", "--author AUTHOR", "Filter PRs by author on homepage") do |author|
    options[:author] = author
  end

  opts.on("-b", "--no-background", "Disable background operations (PR cache refresh and warming)") do
    options[:no_background] = true
  end

  opts.on("-s", "--stream", "Enable progressive streaming for PR analysis pages") do
    options[:streaming] = true
  end

  opts.on("-h", "--help", "Prints this help") do
    puts opts
    exit
  end
end.parse!

# Set environment variables based on options
ENV['BELLS_DEFAULT_AUTHOR'] = options[:author] if options[:author]

if options[:no_background]
  ENV['BELLS_BACKGROUND_REFRESH'] = 'false'
end

if options[:streaming]
  ENV['BELLS_STREAMING'] = 'true'
end

# Execute puma with any remaining arguments
exec('bundle', 'exec', 'puma', *ARGV)
